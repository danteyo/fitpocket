page { height: 100%; overflow: hidden; }
.page-shell { height: 100vh; box-sizing: border-box; padding: calc(env(safe-area-inset-top) + 20rpx) 34rpx calc(env(safe-area-inset-bottom) + 116rpx); position: relative; display: flex; flex-direction: column; }
.topbar { height:72rpx; display:flex; align-items:center; }.user-profile { max-width:320rpx; height:68rpx; margin:0; padding:6rpx 18rpx 6rpx 6rpx; border-radius:34rpx; background:rgba(255,255,255,.72); display:flex; align-items:center; gap:12rpx; box-shadow:0 7rpx 20rpx rgba(36,35,33,.08); }.user-profile image { flex:0 0 56rpx; width:56rpx; height:56rpx; border-radius:50%; background:#EEEAE1; }.user-profile text { min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; color:#494640; font-size:23rpx; font-weight:650; }
