.muscle-callout { position:absolute; z-index:8; left:50%; top:-82rpx; min-width:280rpx; height:62rpx; padding:0 22rpx; box-sizing:border-box; transform:translateX(-50%); display:flex; align-items:center; justify-content:center; gap:10rpx; border-radius:31rpx; background:#FFFFFF; color:#242321; box-shadow:0 10rpx 28rpx rgba(36,35,33,.10); white-space:nowrap; }
