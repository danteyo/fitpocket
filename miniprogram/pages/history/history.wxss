.calendar { will-change:transform,opacity; }.calendar-out-left { animation:calendar-out-left .17s ease-in both; }.calendar-out-right { animation:calendar-out-right .17s ease-in both; }.calendar-in-right { animation:calendar-in-right .23s cubic-bezier(.2,.8,.3,1) both; }.calendar-in-left { animation:calendar-in-left .23s cubic-bezier(.2,.8,.3,1) both; }
@keyframes calendar-out-left { from { opacity:1; transform:translateX(0); } to { opacity:.08; transform:translateX(-72%); } }
@keyframes calendar-out-right { from { opacity:1; transform:translateX(0); } to { opacity:.08; transform:translateX(72%); } }
@keyframes calendar-in-right { from { opacity:.08; transform:translateX(72%); } to { opacity:1; transform:translateX(0); } }
@keyframes calendar-in-left { from { opacity:.08; transform:translateX(-72%); } to { opacity:1; transform:translateX(0); } }
@media (prefers-reduced-motion:reduce) { .calendar-out-left,.calendar-out-right,.calendar-in-right,.calendar-in-left { animation-duration:.01ms; } }
.critical-marker { position:absolute; z-index:4; right:5rpx; top:5rpx; width:20rpx; height:20rpx; pointer-events:none; }
.critical-marker view { position:absolute; left:7rpx; top:0; width:6rpx; height:20rpx; border-radius:5rpx; background:#FFD45A; transform:rotate(45deg); box-shadow:0 0 0 1rpx rgba(120,70,0,.14),0 0 8rpx rgba(255,205,55,.72); }
.critical-marker view::after { content:''; position:absolute; left:-7rpx; top:7rpx; width:20rpx; height:6rpx; border-radius:5rpx; background:inherit; }
.critical-marker view:last-child { display:none; }.critical-marker.critical-strong { width:32rpx; right:2rpx; top:3rpx; }.critical-marker.critical-strong view:first-child { left:1rpx; top:8rpx; transform:rotate(28deg) scale(.72); }.critical-marker.critical-strong view:last-child { display:block; left:18rpx; top:-1rpx; transform:rotate(52deg) scale(.68); }
.calendar .heat.critical-max { outline:4rpx solid #F3C642; outline-offset:-4rpx; box-shadow:0 0 0 3rpx rgba(255,221,91,.46),0 0 16rpx rgba(238,177,26,.58); }.critical-marker.critical-max { display:none; }
